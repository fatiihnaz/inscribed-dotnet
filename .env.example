# Copy to .env and fill in. .env is gitignored; never commit real secrets.

DB_PASSWORD=
CORS_ALLOWED_ORIGINS=https://your-spa.example.com

# Production: keep ASPNETCORE_ENVIRONMENT=Production, set AUTH_ISSUER to the public
# HTTPS URL of this API (the app refuses to start with a localhost issuer in
# Production) and keep AUTH_COOKIE_SECURE=true.
# Local development: Development + http://localhost:5000 + AUTH_COOKIE_SECURE=false.
ASPNETCORE_ENVIRONMENT=Production
AUTH_ISSUER=https://cms.example.com
AUTH_COOKIE_SECURE=true

# Google OAuth client (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI must be: <AUTH_ISSUER>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# This e-mail receives cms:admin on Google login without needing a membership.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Allowed login redirect origin for the seeded admin console client.
ADMIN_CONSOLE_ORIGIN=https://admin.example.com

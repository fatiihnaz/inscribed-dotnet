{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "http://localhost:3001"
  },
  "Auth": {
    "Issuer": "http://localhost:5000",
    "Audience": "inscribed-cms",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "AdminClientKey": "admin",
    "Cookie": {
      "Name": "inscribed_rt",
      "SameSite": "Lax",
      "Secure": true
    },
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/auth/google/callback"
    },
    "Admin": {
      "Role": "cms:admin",
      "BootstrapAdmins": [],
      "ConsoleOrigins": []
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  }
}